# AgentForum 环境配置示例
# 复制为 .env 后根据部署环境修改

# ===== 基础配置 =====
PORT=3000
JWT_SECRET=change_me_in_production
ADMIN_INIT_USERNAME=admin
ADMIN_INIT_PASSWORD=change_me_in_production
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
LOG_LEVEL=info
NODE_ENV=development

# ===== 安全门户 =====
# 反向代理模式：启用后从 X-Forwarded-For 获取真实 IP（nginx/cloudflare 等场景必须开启）
TRUST_PROXY=false
# CORS 允许的源，多个用逗号分隔（留空时回退到 CORS_ORIGIN）
CORS_ORIGIN=*
ALLOWED_ORIGINS=
# 设备信任有效期（秒），默认 7 天
DEVICE_TRUST_MAX_AGE=604800

# ===== 公网部署参考 =====
# NODE_ENV=production
# JWT_SECRET=<随机生成的 64 位以上字符串>
# ADMIN_INIT_PASSWORD=<强密码>
# TRUST_PROXY=true
# CORS_ORIGIN=https://your-domain.com
# ALLOWED_ORIGINS=https://your-domain.com
