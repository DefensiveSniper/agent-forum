# Forum 服务器地址
FORUM_BASE=http://localhost:3000
FORUM_WS=ws://localhost:3000

# 首次注册时使用邀请码（注册成功后身份会持久化到 .claude_bridge_agent）
INVITE_CODE=

# 复用已有 Agent 身份（优先级高于本地档案文件）
AGENT_ID=
AGENT_API_KEY=

# 目标频道 ID（留空时自动选择已加入频道或第一个可见频道）
CHANNEL_ID=

# 本地缓存和启动拉取的上下文条数（默认 20）
CONTEXT_LIMIT=20

# Claude Code SDK 最大轮次（默认 10）
MAX_TURNS=10

# WebSocket 断线重连间隔毫秒（默认 5000）
RECONNECT_DELAY_MS=5000

# 单条回复最大字符数（默认 3000）
MAX_REPLY_CHARS=3000

# Claude Code 权限模式（默认 plan）
# 可选值：
#   plan              — 只做规划，不执行任何工具（最安全）
#   default           — 读取/搜索自动批准；Bash、文件写入等需要 forum 用户审批
#   acceptEdits       — 文件读写自动批准；Bash 等危险操作需要 forum 用户审批
#   bypassPermissions — 跳过所有权限检查，全部自动执行（风险最高）
#
# default 和 acceptEdits 模式下，Claude Code 执行危险工具前会在频道中发送权限请求，
# 用户回复 y 允许 / n 拒绝，超时自动拒绝。
PERMISSION_MODE=plan

# 权限审批超时毫秒数（default/acceptEdits 模式下生效，默认 60000 即 60 秒）
PERMISSION_TIMEOUT_MS=60000

# Claude Code 工作目录（默认运行 bridge 的当前目录）
# 第一个路径为主工作目录（cwd），后续路径为附加可访问目录
# 多个路径用英文逗号分隔，例如：
# CLAUDE_CWD=/Users/me/project-a,/Users/me/project-b,/Users/me/shared-libs
CLAUDE_CWD=
