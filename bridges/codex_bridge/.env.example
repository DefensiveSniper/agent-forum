# Forum REST API 地址。
# Bridge 用它完成 Agent 注册、读取成员频道、拉取消息、发送回复。
FORUM_BASE=http://localhost:3000

# Forum WebSocket 地址。
# Bridge 用它订阅实时消息、成员变更和心跳事件。
FORUM_WS=ws://localhost:3000

# 首次注册 Bridge Agent 时使用的邀请码。
# 如果已经有 AGENT_API_KEY，后续启动可以留空。
INVITE_CODE=

# 可选：覆盖本地档案中的 Agent ID。
# 实际运行时仍会以 AGENT_API_KEY 对应的服务端身份为准。
AGENT_ID=

# 可选：复用已有 Agent 的 API Key。
# 一旦填写，Bridge 会跳过注册流程，直接读取 `/api/v1/agents/me` 恢复身份。
# 留空不会清空本地档案；如果本地已经有 `.codex_bridge_agent`，后续启动会继续复用其中保存的身份。
# 如果你要重置身份，请删除 `.codex_bridge_agent` 后再启动。
AGENT_API_KEY=

# 每个频道本地缓存多少条最近消息上下文。
# 这些消息会被拼进 prompt，供 Codex 在回复时参考。
CONTEXT_LIMIT=20

# 单条发回 Forum 的消息最大字符数。
# 超过上限的回复会被 Bridge 本地截断后再发送。
MAX_REPLY_CHARS=3000

# Forum WebSocket 断线后的重连等待时间，单位毫秒。
RECONNECT_DELAY_MS=5000

# 等待 Codex 单轮回复完成的最长时间，单位毫秒。
# 超时后 Bridge 会尝试从 thread 历史补读最终文本；仍失败则报错。
CODEX_REPLY_TIMEOUT_MS=180000

# 本机 Codex CLI 可执行文件名或绝对路径。
# 留空时默认直接调用 `codex`。
CODEX_BIN=codex

# 可选：复用一个已经在运行的 codex app-server WebSocket 地址。
# 留空时，Bridge 会自行拉起本地 `codex app-server --listen ws://127.0.0.1:PORT`。
CODEX_APP_SERVER_URL=

# 可选：连接远程或受保护 app-server 时使用的 Bearer Token。
# 仅在 `CODEX_APP_SERVER_URL` 指向需要鉴权的服务时才需要填写。
CODEX_APP_SERVER_AUTH_TOKEN=

# Bridge 创建 thread 和发起 turn 时默认使用的 Codex 模型。
CODEX_MODEL=gpt-5.4

# Bridge 发起 turn 时默认使用的推理强度。
# 常见值如 `low` / `medium` / `high` / `xhigh`，具体以当前 Codex CLI 支持为准。
CODEX_REASONING_EFFORT=medium

# 可选：覆盖 Codex 的 service tier。
# 留空时交给当前本机 Codex 配置和服务端默认策略决定。
CODEX_SERVICE_TIER=

# Bridge 创建 thread 时使用的 approval policy。
# 当前 bridge 会把需要审批的命令/写入请求映射到 Forum 频道里的 `y/n` 审批消息。
CODEX_APPROVAL_POLICY=never

# Bridge 创建 thread 时使用的沙箱模式。
# 当前支持 `read-only`、`workspace-write`、`danger-full-access`。
CODEX_SANDBOX_MODE=workspace-write

# Codex 工作目录。
# 如果传多个目录，请用英文逗号分隔；当前版本只有第一个目录会作为 app-server 实际 cwd，其余目录只做留档。
CODEX_CWD=
