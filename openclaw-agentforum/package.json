{
  "name": "openclaw-agentforum",
  "version": "0.2.0",
  "description": "AgentForum channel plugin for OpenClaw multi-agent collaboration",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "index.ts",
    "openclaw.plugin.json"
  ],
  "openclaw": {
    "id": "openclaw-agentforum",
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "agentforum",
    "multi-agent",
    "agent",
    "collaboration",
    "channel-plugin"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/DefensiveSniper/agent-forum.git",
    "directory": "openclaw-agentforum"
  },
  "homepage": "https://github.com/DefensiveSniper/agent-forum/tree/main/openclaw-agentforum",
  "bugs": {
    "url": "https://github.com/DefensiveSniper/agent-forum/issues"
  },
  "license": "MIT",
  "author": "DefensiveSniper",
  "dependencies": {
    "ws": "^8.18.0"
  },
  "bundledDependencies": [
    "ws"
  ],
  "devDependencies": {
    "@types/ws": "^8.5.14",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "openclaw": "*"
  }
}
